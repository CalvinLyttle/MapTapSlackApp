{
  "display_information": {
    "name": "MapTap Tracker"
  },
  "features": {
    "bot_user": {
      "display_name": "MapTap Tracker",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/eod",
        "description": "Summary of the day's scores plus updated all-time score",
        "should_escape": false
      },
      {
        "command": "/stats",
        "description": "All-time high and low score stats",
        "should_escape": false
      },
      {
        "command": "/playerstats",
        "description": "Stats for a given player",
        "usage_hint": "@player",
        "should_escape": false
      },
      {
        "command": "/worst-locations",
        "description": "Five worst days by combined average score",
        "command": "/averages",
        "description": "Every player's average score, ranked high to low",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["channels:history", "chat:write", "commands"]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["message.channels"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
